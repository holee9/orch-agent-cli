{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "release_readiness.schema.json",
  "title": "ReleaseReadiness",
  "description": "Release readiness and consensus schema for multi-AI orchestration.",
  "type": "object",
  "required": [
    "spec_id",
    "version",
    "timestamp",
    "consensus_result",
    "agent_votes",
    "overall_score",
    "veto_applied",
    "test_coverage",
    "security_scan_passed",
    "release_notes_ready",
    "final_decision"
  ],
  "additionalProperties": false,
  "properties": {
    "spec_id": {
      "type": "string",
      "description": "Identifier of the specification being evaluated for release."
    },
    "version": {
      "type": "string",
      "description": "Version string of the release candidate."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the release readiness assessment was recorded."
    },
    "consensus_result": {
      "type": "object",
      "description": "Aggregated consensus outcome from all agent votes.",
      "required": ["status", "score"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "description": "Overall consensus decision.",
          "enum": ["approved", "rejected", "escalated"]
        },
        "score": {
          "type": "number",
          "description": "Aggregated consensus score."
        }
      }
    },
    "agent_votes": {
      "type": "array",
      "description": "Individual votes from each participating agent.",
      "items": {
        "type": "object",
        "required": ["agent_id", "vote", "weight", "rationale"],
        "additionalProperties": false,
        "properties": {
          "agent_id": {
            "type": "string",
            "description": "Identity of the voting agent.",
            "enum": ["claude", "codex", "gemini"]
          },
          "vote": {
            "type": "string",
            "description": "Agent's vote on release readiness.",
            "enum": ["approve", "reject", "veto"]
          },
          "weight": {
            "type": "integer",
            "description": "Voting weight assigned to this agent."
          },
          "rationale": {
            "type": "string",
            "description": "Explanation for the agent's vote."
          }
        }
      }
    },
    "overall_score": {
      "type": "number",
      "description": "Weighted overall readiness score between 0 and 1.",
      "minimum": 0,
      "maximum": 1
    },
    "veto_applied": {
      "type": "boolean",
      "description": "Whether a veto was applied by any agent."
    },
    "veto_reason": {
      "type": "string",
      "description": "Reason for the veto. Required when veto_applied is true."
    },
    "test_coverage": {
      "type": "number",
      "description": "Test coverage ratio between 0 and 1.",
      "minimum": 0,
      "maximum": 1
    },
    "security_scan_passed": {
      "type": "boolean",
      "description": "Whether the security scan passed without critical findings."
    },
    "release_notes_ready": {
      "type": "boolean",
      "description": "Whether release notes have been prepared."
    },
    "final_decision": {
      "type": "string",
      "description": "Final release decision.",
      "enum": ["release", "hold", "escalate_to_human"]
    }
  },
  "if": {
    "properties": {
      "veto_applied": { "const": true }
    }
  },
  "then": {
    "required": ["veto_reason"]
  }
}
