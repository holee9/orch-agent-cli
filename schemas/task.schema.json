{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "task.schema.json",
  "title": "Task",
  "description": "Task tracking schema for multi-AI orchestration workflows.",
  "type": "object",
  "required": [
    "id",
    "type",
    "status",
    "assigned_to",
    "priority",
    "title",
    "description",
    "created_at",
    "updated_at",
    "blocks",
    "blocked_by"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique task identifier."
    },
    "type": {
      "type": "string",
      "description": "Task type classification.",
      "enum": ["analysis", "design", "implementation", "review", "testing", "release"]
    },
    "status": {
      "type": "string",
      "description": "Current task status.",
      "enum": ["open", "claimed", "in_progress", "review", "done", "blocked"]
    },
    "assigned_to": {
      "type": "string",
      "description": "Agent or entity assigned to this task.",
      "enum": ["claude", "codex", "gemini", "human", "unassigned"]
    },
    "priority": {
      "type": "string",
      "description": "Task priority level.",
      "enum": ["P1", "P2", "P3"]
    },
    "title": {
      "type": "string",
      "description": "Short descriptive title of the task."
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the task."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the task was created."
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the task was last updated."
    },
    "github_issue_number": {
      "type": "integer",
      "description": "Associated GitHub issue number."
    },
    "blocks": {
      "type": "array",
      "description": "List of task IDs that cannot start until this task is done.",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "blocked_by": {
      "type": "array",
      "description": "List of task IDs that must be completed before this task can start.",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "result_summary": {
      "type": "string",
      "description": "Summary of the task result upon completion."
    }
  }
}
